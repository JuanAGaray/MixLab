# Copiar a .env y completar valores reales.
# Nunca subas el service_role a un repo público.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=True

# Postgres (pooler)
DB_NAME=postgres
DB_USER=postgres.TU_PROJECT_REF
DB_PASSWORD=
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=5432
DATABASE_URL_POOLER=postgresql://postgres.TU_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
USE_SQLITE=false

# Storage — obligatorio en Vercel (todo /media va al bucket)
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=Mixlab
FORCE_SUPABASE_MEDIA=false
